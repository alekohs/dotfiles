[sqlfluff]
dialect = tsql
templater = raw
max_line_length = 200
# capitalisation.identifiers: legacy schema has fixed mixed-case names (Finnish/Swedish)
# structure.column_order: would reorder VIEW columns (changes output ordinal order)
exclude_rules = capitalisation.identifiers, structure.column_order

[sqlfluff:layout:type:alias_expression]
spacing_before = align
align_within = select_clause
align_scope = bracketed

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4
indented_joins = true
indented_using_on = true
implicit_indents = allow

[sqlfluff:layout:type:comma]
line_position = trailing

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
extended_capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = upper
